{
  "name": "@llmgates_api/pi-llmgates-provider",
  "version": "0.1.6",
  "description": "Pi provider extension for LLMGates: dynamic models from /v1/models and /login setup",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "llmgates",
    "tps"
  ],
  "license": "MIT",
  "author": "llmgates_api",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ax128/pi-llmgates.git"
  },
  "homepage": "https://github.com/ax128/pi-llmgates#readme",
  "bugs": {
    "url": "https://github.com/ax128/pi-llmgates/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts",
      "./extensions/tps.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.81.0 <0.82.0",
    "@earendil-works/pi-coding-agent": ">=0.81.0 <0.82.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.81.1",
    "@earendil-works/pi-coding-agent": "0.81.1",
    "@types/node": "^22.15.21",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ]
}
